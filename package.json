{
  "name": "aurora-analytics-site",
  "version": "1.0.0",
  "description": "Commercial-ready marketing site and API backend for Aurora Analytics",
  "main": "server/index.js",
  "type": "commonjs",
  "scripts": {
    "dev": "nodemon server/index.js",
    "start": "node server/index.js",
    "test": "cross-env NODE_ENV=test jest --runInBand"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "helmet": "^7.0.0",
    "morgan": "^1.10.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "supertest": "^7.1.1"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/server/tests/**/*.test.js"
    ],
    "setupFilesAfterEnv": [
      "<rootDir>/server/tests/setup.js"
    ]
  }
}
